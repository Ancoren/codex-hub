# Admin password
HUB_ADMIN_PASSWORD=your-strong-password

# Gateway API key (optional, leave empty to disable)
HUB_API_KEY=your-hub-api-key

# Load balancing strategy: least_used | round_robin | random | priority
HUB_STRATEGY=least_used

# Health check interval (seconds)
HUB_HEALTH_CHECK_INTERVAL=300

# Auto refresh tokens
HUB_AUTO_REFRESH_TOKEN=true

# Server
HUB_PORT=8080
HUB_LOG_LEVEL=INFO
